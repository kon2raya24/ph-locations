{
  "name": "ph-locations",
  "version": "1.0.0",
  "description": "Comprehensive Philippine administrative location data — regions, provinces, cities/municipalities, and barangays with TypeScript support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "philippines",
    "locations",
    "regions",
    "provinces",
    "cities",
    "municipalities",
    "barangays",
    "PSGC",
    "philippine-geography",
    "address",
    "location-data",
    "typescript"
  ],
  "author": "kon2raya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kon2raya24/ph-locations.git"
  },
  "homepage": "https://github.com/kon2raya24/ph-locations#readme",
  "bugs": {
    "url": "https://github.com/kon2raya24/ph-locations/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
